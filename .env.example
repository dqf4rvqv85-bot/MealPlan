# Copy to .env and fill in. .env is git-ignored.

# Anthropic API key for recipe extraction (claude-opus-4-8 vision).
ANTHROPIC_API_KEY=

# Tesco online groceries login (used only by the Playwright basket step).
TESCO_EMAIL=
TESCO_PASSWORD=

# Paths (defaults are fine for local use).
PDF_PATH=recipes.pdf
DB_PATH=mealplanner.db
# Where Playwright stores the logged-in Tesco browser session.
TESCO_STORAGE_STATE=tesco_state.json
